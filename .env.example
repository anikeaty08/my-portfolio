# Backend (Express)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority"
# If your password contains special characters (like @ : / ? # & %),
# you must URL-encode it in the URI or Mongo will fail to connect.
PORT=5174
JWT_SECRET="change-this-to-a-long-random-string"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
# Prefer a hash in production (bcrypt). If set, it is used instead of ADMIN_PASSWORD.
# Example: node -e "import bcrypt from 'bcryptjs'; console.log(await bcrypt.hash('yourPass', 12))"
ADMIN_PASSWORD_HASH=""
# Comma-separated allowed origins for CORS (optional)
CLIENT_ORIGIN="http://localhost:5173"
